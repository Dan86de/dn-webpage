---
import Layout from "@/layouts/Layout.astro";
---

<style is:inline>
  /* Tell browsers & extensions to use appropriate color scheme for inputs */
  input.newsletter-input {
    color-scheme: light;
  }
  .dark input.newsletter-input {
    color-scheme: dark;
  }

  /*
   * Chrome always forces a light-blue autofill background that can't
   * be reliably overridden, so always use dark text to stay readable.
   */
  input.newsletter-input:-webkit-autofill,
  input.newsletter-input:-webkit-autofill:hover,
  input.newsletter-input:-webkit-autofill:focus,
  input.newsletter-input:-webkit-autofill:active {
    -webkit-text-fill-color: #1a1a1a !important;
    caret-color: #1a1a1a !important;
  }
</style>

<Layout>
  <div class="flex flex-col grow px-(--inline-padding)">
    <div class="flex flex-col grow mx-auto max-w-4xl w-full">
      <div class="flex flex-col items-center justify-center grow">
        <h1 class="font-medium tracking-tight text-center text-balance">
          Join engineers who are <span class="bg-brand-gradient bg-clip-text text-transparent">thriving</span> in the AI era
        </h1>
        <p class="mx-auto mt-4 max-w-[48ch] text-lg text-pretty text-center text-gray-900">
          Practical insights on using AI to write better code, ship faster, and grow your career — delivered weekly.
        </p>
        <form
          class="mt-10 flex flex-col gap-4 w-full max-w-xs"
          action="https://app.kit.com/forms/9259766/subscriptions"
          method="post"
        >
          <div class="flex flex-col gap-1.5">
            <label for="sp-name" class="text-sm font-medium text-gray-1100">First Name<span class="ml-1 text-orange-500">*</span></label>
            <input
              type="text"
              id="sp-name"
              name="fields[first_name]"
              placeholder="Name"
              class="newsletter-input rounded-lg ring-1 ring-gray-500 dark:ring-gray-400 bg-white dark:bg-white/5 px-4 py-3 max-tablet:text-base/6 text-sm/6 text-gray-1200 placeholder:text-gray-800 focus:outline-2 focus:outline-orange-500 focus:-outline-offset-1"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="sp-email" class="text-sm font-medium text-gray-1100">Email<span class="ml-1 text-orange-500">*</span></label>
            <input
              type="email"
              id="sp-email"
              name="email_address"
              placeholder="you@example.com"
              required
              class="newsletter-input rounded-lg ring-1 ring-gray-500 dark:ring-gray-400 bg-white dark:bg-white/5 px-4 py-3 max-tablet:text-base/6 text-sm/6 text-gray-1200 placeholder:text-gray-800 focus:outline-2 focus:outline-orange-500 focus:-outline-offset-1"
            />
          </div>
          <button
            type="submit"
            class="mt-1 rounded-lg bg-brand-gradient px-4 py-3 text-sm font-medium text-white transition-opacity hover:opacity-90 cursor-pointer"
          >
            Subscribe
          </button>
        </form>
        <p class="mt-3 text-gray-800 text-sm">I respect your privacy. Unsubscribe at any time.</p>
      </div>
    </div>
  </div>
</Layout>
